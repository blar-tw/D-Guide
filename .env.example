# Copy this file to .env and fill in your real values.
# .env is gitignored and must never be committed.

# Google Maps Platform API key (Geocoding + Directions API)
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Picovoice access key (Porcupine wake word engine)
# https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your-picovoice-access-key

# Absolute path to your Google Cloud service-account JSON (Speech-to-Text)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/api_key.json

# Anthropic API key for the LLM command-parsing node (optional; without it
# llm_node falls back to an offline rule-based parser)
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Non-secret runtime settings (override as needed) ---

# Flight controller target for followpp_server / scripts/flight_test.py
# ArduPilot SITL (default): tcp:127.0.0.1:5760 | real Pixhawk: /dev/ttyACM0
# DRONE_CONNECTION=tcp:127.0.0.1:5760
# DRONE_BAUD=57600

# Takeoff / waypoint-following altitude in meters
# CRUISE_ALTITUDE=5.0

# Microphone index for the wake-word nodes (-1 = system default). List with:
#   python3 -c "import pvrecorder; print(pvrecorder.PvRecorder.get_available_devices())"
# PVRECORDER_DEVICE_INDEX=-1

# Fallback origin for voice commands like "take me to X" (llm_node)
# DEFAULT_ORIGIN=Hukou Station

# Claude model used by llm_node (default: claude-opus-4-8)
# LLM_MODEL=claude-opus-4-8
