# Copy this file to .env and fill in your real values.
# .env is gitignored and must never be committed.

# Google Maps Platform API key (Geocoding + Directions API)
# https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Picovoice access key (Porcupine wake word engine)
# https://console.picovoice.ai/
PICOVOICE_ACCESS_KEY=your-picovoice-access-key

# Absolute path to your Google Cloud service-account JSON (Speech-to-Text)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/api_key.json

# Anthropic API key for the LLM command-parsing node (optional; without it
# llm_node falls back to an offline rule-based parser)
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=your-anthropic-api-key

# --- Non-secret runtime settings (override as needed) ---

# Flight controller link (dwa_navigator / followpp_server / flight_test.py)
# Real Pixhawk over USB: /dev/ttyACM0 (baud 115200) | fast UART: /dev/serial0 (921600)
# ArduPilot SITL: tcp:127.0.0.1:5760 (baud 57600)
# DRONE_CONNECTION=/dev/ttyACM0
# DRONE_BAUD=115200

# Takeoff / cruise altitude in metres AGL
# CRUISE_ALTITUDE=5.0
# Max horizontal speed in m/s (walking pace for a guide drone)
# NAV_SPEED_MAX=1.5

# --- Obstacle avoidance (dwa_navigator) ---
# 2D LiDAR scan topic (sensor_msgs/LaserScan)
# LIDAR_TOPIC=/scan
# Mirror the scan across the body axis to match the NED/FRD frame. Default true
# for a standard forward-facing REP-103 laser; verify with the spin test in
# docs/installation.md and flip if left/right are swapped.
# LIDAR_FLIP_Y=true
# Planner keep-out radius in metres (>= half the airframe width)
# ROBOT_RADIUS=0.35
# LiDAR beam downsample stride (higher = faster search, coarser point cloud)
# LIDAR_STRIDE=2

# --- Voice front-end ---
# Microphone index (-1 = system default). List with:
#   python3 -c "import pvrecorder; print(pvrecorder.PvRecorder.get_available_devices())"
# MIC_DEVICE_INDEX=-1
# PVRECORDER_DEVICE_INDEX=-1
# Speech-to-text language (BCP-47) and capture length (seconds)
# STT_LANGUAGE=zh-TW
# STT_RECORD_SECONDS=5

# --- LLM command parsing ---
# Fallback origin for voice commands like "take me to X" (llm_node)
# DEFAULT_ORIGIN=Hukou Station
# Claude model used by llm_node (default: claude-opus-4-8)
# LLM_MODEL=claude-opus-4-8
